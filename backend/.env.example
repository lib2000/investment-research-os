# Local development only. Do not commit real secrets.
DEFAULT_BROKER=KIWOOM
DEV_USER_TOKEN=dev-local-token

# Kiwoom REST API credentials
KIWOOM_API_KEY=********
KIWOOM_API_SECRET=********
KIWOOM_BASE_URL=https://api.kiwoom.com
KIWOOM_MOCK_BASE_URL=https://mockapi.kiwoom.com
KIWOOM_USE_MOCK=true

# IP registered in Kiwoom APP KEY management.
# Local development can use the current public IP shown on Kiwoom's page.
# Production should use a fixed outbound IP such as a NAT Gateway IP.
KIWOOM_REGISTERED_IP=********

# Application secret material
SECRET_SALT=********

# Brokerage token rotation.
# Kiwoom currently issues client_credentials access tokens; refresh token support is optional.
TOKEN_EXPIRY_BUFFER_SECONDS=300
KIWOOM_ALLOW_REFRESH_TOKEN=false

# Local persistence. Production should use PostgreSQL.
LOCAL_DB_PATH=investment_journal.sqlite3

# SQLite local development concurrency.
# WAL allows readers to continue while background sync writes.
SQLITE_ENABLE_WAL=true
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_RESTRICT_FILE_PERMISSIONS=true

# Optional. Requires a SQLCipher-enabled sqlite driver; default Python sqlite3 is not enough.
# If this is set without SQLCipher support, backend startup fails instead of silently storing plaintext.
SQLITE_ENCRYPTION_KEY=

# SQLite hot backup.
# Startup creates a backup when no recent backup exists, then removes old backup files.
DB_BACKUP_ON_STARTUP=true
DB_BACKUP_DIR=backups
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_INTERVAL_HOURS=168

# Historical sync rate-limit protection.
# Keep these conservative for brokerage APIs with strict rate limits.
HISTORY_SYNC_MIN_DELAY_SECONDS=0.0
HISTORY_SYNC_RATE_LIMIT_SECONDS=2.0
HISTORY_SYNC_REQUEST_DELAY_SECONDS=2.0
HISTORY_SYNC_MAX_RETRIES=5
HISTORY_SYNC_BACKOFF_INITIAL_SECONDS=2.0
HISTORY_SYNC_BACKOFF_MAX_SECONDS=60.0
HISTORY_SYNC_BACKOFF_MULTIPLIER=2.0
KIWOOM_PAGE_DELAY_SECONDS=0.4

# Data provider keys. Leave blank to disable a provider.
DATA_PROVIDER_MODE=kis
AUTO_INJECT_ANALYSIS_DATA=true
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP_TIMEOUT_SECONDS=8
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_USE_MOCK=false
KIS_ALLOW_TOKEN_ISSUE=false
KIS_ACCESS_TOKEN=
KIS_ACCESS_TOKEN_FILE=
# Default token cache stays under research_vault, which is ignored by Git.
# Do not point this to a tracked source directory.
KIS_TOKEN_CACHE_FILE=../research_vault/_system/kis_access_token.json
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_FILING_AUTO_REFRESH=true
DART_FILING_REFRESH_HOURS=6
# Wider than daily so a stopped local server can still catch recently missed quarterly reports.
DART_FILING_LOOKBACK_DAYS=45
DART_FILING_MAX_ITEMS_PER_TICKER=20
FINANCIAL_DATASETS_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=
ALPHA_VANTAGE_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Korea public-data providers. Leave keys blank to disable.
NPS_ODCLOUD_API_KEY=
NPS_ODCLOUD_BASE_URL=https://api.odcloud.kr/api
NPS_ODCLOUD_TIMEOUT_SECONDS=4
NPS_ODCLOUD_MAX_PAGES=1

# Korea Customs Service public data.
# Item/country trade is used for sector/exporter signals. Total trend is the separate
# 1st/11th/21st export-import trend API; if it returns 403, check data.go.kr service authorization.
CUSTOMS_TRADE_ENABLED=true
CUSTOMS_TRADE_API_KEY=
CUSTOMS_TRADE_API_URL=https://apis.data.go.kr/1220000/nitemtrade/getNitemtradeList
CUSTOMS_TRADE_TOTAL_API_URL=https://apis.data.go.kr/1220000/Newtrade/getNewtradeList
CUSTOMS_TRADE_TOTAL_DOCS_URL=https://www.data.go.kr/data/15102108/openapi.do
CUSTOMS_TRADE_TIMEOUT_SECONDS=8
CUSTOMS_TRADE_MAX_ROWS=100
CUSTOMS_TRADE_RELEASE_DAYS=1,11,21

# KCIF report watch. Put real ID/password only in backend\.env, never in chat or Git.
# The app uses authenticated access only to derive signals; it does not auto-save PDFs/full text.
KCIF_USE_LOGIN=true
KCIF_USERNAME=
KCIF_PASSWORD=
KCIF_REPORT_LIST_URL=https://www.kcif.or.kr/annual/reportList
KCIF_LOGIN_PROC_URL=https://www.kcif.or.kr/webUser/loginProc
KCIF_TIMEOUT_SECONDS=12

# EMERiCs/CSF/KIEP regional and macro source watch.
# Full page text is not stored; only metadata, links, and derived relevance signals are saved.
REGIONAL_BUSINESS_SOURCES_ENABLED=true
REGIONAL_BUSINESS_SOURCES_AUTO_REFRESH=true
REGIONAL_BUSINESS_SOURCES_REFRESH_HOURS=24
REGIONAL_BUSINESS_SOURCES_TIMEOUT_SECONDS=10
COMPANY_IR_SOURCES_ENABLED=true
COMPANY_IR_SOURCES_AUTO_REFRESH=true
COMPANY_IR_SOURCES_REFRESH_HOURS=24
COMPANY_IR_SOURCES_TIMEOUT_SECONDS=12
COMPANY_IR_SOURCES_MAX_ITEMS=20
# Optional JSON array: [{"ticker":"JOBY","company_name":"Joby Aviation","source_url":"https://ir.jobyaviation.com/news-events/press-releases"}]
COMPANY_IR_SOURCES_JSON=
REGIONAL_BUSINESS_SOURCES_MAX_ITEMS=40

# Auxiliary Korean market index collection from Naver Finance.
# This is a best-effort helper, not an official exchange API.
NAVER_FINANCE_ENABLED=true
NAVER_FINANCE_BASE_URL=https://m.stock.naver.com
NAVER_FINANCE_TIMEOUT_SECONDS=6

# Company-name to ticker registry refresh.
# Uses KRX/KIND listed-company data and Nasdaq Trader symbol directories.
TICKER_REGISTRY_AUTO_REFRESH=true
TICKER_REGISTRY_REFRESH_HOURS=24
TICKER_REGISTRY_TIMEOUT_SECONDS=12
TICKER_REGISTRY_KRX_KIND_URL=https://kind.krx.co.kr/corpgeneral/corpList.do?method=download&searchType=13
TICKER_REGISTRY_NASDAQ_LISTED_URL=https://www.nasdaqtrader.com/dynamic/SymDir/nasdaqlisted.txt
TICKER_REGISTRY_NASDAQ_OTHER_URL=https://www.nasdaqtrader.com/dynamic/SymDir/otherlisted.txt

# Naver Finance research metadata/PDF signal extraction.
# Full report text is not stored; only metadata, structured signals, and short verification snippets are saved.
NAVER_RESEARCH_ENABLED=true
NAVER_RESEARCH_AUTO_REFRESH=true
NAVER_RESEARCH_REFRESH_HOURS=24
NAVER_RESEARCH_MAX_ITEMS=40
NAVER_RESEARCH_PDF_EXTRACT_ENABLED=true
NAVER_RESEARCH_PDF_SNIPPET_MAX_CHARS=900
NAVER_MARKET_CLOSE_AUTO_JOURNAL=true
NAVER_MARKET_CLOSE_JOURNAL_TIME=08:30

# Daily review candidates. These are saved as a separate tracking item under
# research_vault/_system/daily_recommendations.json.
DAILY_RECOMMENDATIONS_ENABLED=true
DAILY_RECOMMENDATIONS_TIME=09:00
DAILY_RECOMMENDATIONS_TRACKING_ENABLED=true
